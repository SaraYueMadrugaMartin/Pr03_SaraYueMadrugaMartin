<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UndirLaFlota.MainPage">

    <ScrollView>
        <!--Contenedor para ambos tableros.-->
        <Grid RowDefinitions="*"
              ColumnDefinitions="*">
            
            <HorizontalStackLayout Padding="20" Spacing="50" HorizontalOptions="Center">

                <!--Espacio para el tablero del jugador 1.-->
                <VerticalStackLayout Spacing="10" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="Jugador 1" FontSize="20"/>
                    <Grid x:Name="TableroGridPlayer01"/>
                </VerticalStackLayout>

                <!--Espacio para el tablero del jugador 2 (IA).-->
                <VerticalStackLayout Spacing="10" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="Jugador 2" FontSize="20"/>
                    <Grid x:Name="TableroGridPlayer02"/>
                </VerticalStackLayout>

            </HorizontalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
