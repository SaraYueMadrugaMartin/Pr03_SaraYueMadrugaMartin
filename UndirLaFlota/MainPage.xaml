<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UndirLaFlota.MainPage">

    <ScrollView>
        <!--Contenedor para ambos tableros.-->
        <Grid ColumnDefinitions="*,*"
              RowDefinitions="Auto,*,Auto"
              Padding="10"
              RowSpacing="10"
              ColumnSpacing="20">

            <!--Tablero del Jugador 1-->
            <VerticalStackLayout Grid.Row="1"
                                 Grid.Column="0"
                                 Spacing="15"
                                 HorizontalOptions="Center">
                
                <Label Text="Jugador 1"
                       FontSize="15"
                       HorizontalOptions="Center"/>
                
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label Text="Barcos hundidos del oponente:" FontSize="13" TextColor="Gray"/>
                    <Label x:Name="CounterBoatsPlayer01" Text="0" FontSize="13" FontAttributes="Bold" TextColor="Green"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label Text="Barcos propios en pie:" FontSize="13" TextColor="Gray"/>
                    <Label x:Name="CounterLostBoatsPlayer01" Text="0" FontSize="13" FontAttributes="Bold" TextColor="Red"/>
                </HorizontalStackLayout>

                <Grid x:Name="TableroGridPlayer01"
                      HorizontalOptions="Center"
                      VerticalOptions="Center"/>
            </VerticalStackLayout>

            <!--Tablero del jugador 2-->
            <VerticalStackLayout Grid.Row="1"
                                 Grid.Column="1"
                                 Spacing="15"
                                 HorizontalOptions="Center">

                <Label Text="Jugador 2"
                       FontSize="15"
                       HorizontalOptions="Center"/>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label Text="Barcos hundidos del oponente:" FontSize="13" TextColor="Gray"/>
                    <Label x:Name="CounterBoatsPlayer02" Text="0" FontSize="13" FontAttributes="Bold" TextColor="Green"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label Text="Barcos propios en pie:" FontSize="13" TextColor="Gray"/>
                    <Label x:Name="CounterLostBoatsPlayer02" Text="0" FontSize="13" FontAttributes="Bold" TextColor="Red"/>
                </HorizontalStackLayout>

                <Grid x:Name="TableroGridPlayer02"
                      HorizontalOptions="Center"
                      VerticalOptions="Center"/>
            </VerticalStackLayout>

            <!--Botón para confirmar posiciones escogidas por el jugador 1-->
            <Button Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Text="Aceptar colocación"
                    HorizontalOptions="Center"
                    Clicked="OnAceptarClicked"/>
        </Grid>
    </ScrollView>
</ContentPage>